{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/apps/assets/$1"
    },
    {
      "source": "/admin",
      "destination": "/apps/admin/index.html"
    },
    {
      "source": "/book",
      "destination": "/apps/book/index.html"
    },
    {
      "source": "/book/(.*)",
      "destination": "/apps/book/$1"
    },
    {
      "source": "/audio",
      "destination": "/apps/audiobook/index.html"
    },
    {
      "source": "/audio/(.*)",
      "destination": "/apps/audiobook/$1"
    },
    {
      "source": "/wallpapers",
      "destination": "/apps/wallpapers/index.html"
    },
    {
      "source": "/wallpapers/(.*)",
      "destination": "/apps/wallpapers/$1"
    },
    {
      "source": "/bundle",
      "destination": "/apps/bundle/index.html"
    },
    {
      "source": "/thank-you",
      "destination": "/apps/thank-you/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/main/$1"
    }
  ]
}
