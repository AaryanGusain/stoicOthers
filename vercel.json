{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "outputDirectory": ".",
  "functions": {
    "api/**/*.js": {
      "includeFiles": "node_modules/.prisma/client/**"
    }
  },
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/apps/assets/$1"
    },
    {
      "source": "/admin",
      "destination": "/apps/admin"
    },
    {
      "source": "/book",
      "destination": "/apps/book"
    },
    {
      "source": "/book/(.*)",
      "destination": "/apps/book/$1"
    },
    {
      "source": "/audio",
      "destination": "/apps/audiobook"
    },
    {
      "source": "/audio/(.*)",
      "destination": "/apps/audiobook/$1"
    },
    {
      "source": "/wallpapers",
      "destination": "/apps/wallpapers"
    },
    {
      "source": "/wallpapers/(.*)",
      "destination": "/apps/wallpapers/$1"
    },
    {
      "source": "/bundle",
      "destination": "/apps/bundle"
    },
    {
      "source": "/thank-you",
      "destination": "/apps/thank-you"
    },
    {
      "source": "/privacy",
      "destination": "/apps/privacy"
    },
    {
      "source": "/terms",
      "destination": "/apps/terms"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/main/$1"
    }
  ]
}
